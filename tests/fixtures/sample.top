    3   CT    1      ALA      CB    3     -0.1823  12.011
    4   CT    1      ALA      C     4      0.5973  12.011
    5   CT    1      ALA      O     5     -0.5679  15.999
    6   CT    2      GLY      N     6     -0.4157  14.007
    7   CT    2      GLY      CA    7      0.0337  12.011
    8   CT    2      GLY      C     8      0.5973  12.011
    9   CT    2      GLY      O     9     -0.5679  15.999

[ bonds ]
; ai  aj  funct
  1   2   1
  2   3   1
  2   4   1
  4   5   1
  4   6   1
  6   7   1
  7   8   1
  8   9   1

[ moleculetype ]
; Name  nrexcl
SOL     1

[ atoms ]
;   nr  type  resnr  residue  atom  cgnr  charge   mass
    1   OW    1      SOL      OW    1     -0.834   15.999
    2   HW    1      SOL      HW1   2      0.417    1.008
    3   HW    1      SOL      HW2   3      0.417    1.008

[ system ]
; Name
Test System

[ molecules ]
; Compound  #mols
Protein     1
SOL         3
